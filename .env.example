# Copy this file to .env and fill in real values before running.
# NEVER commit a real .env file — it's already in .gitignore.

# --- General ---
APP_NAME=PROMETHEUS Quant Lab
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Security / JWT ---
# Generate a strong random value, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
# MUST be overridden with a real secret before staging/production use.
SECRET_KEY=CHANGE_ME_INSECURE_DEV_ONLY_SECRET_KEY_MIN_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database ---
# Used directly when running the backend without Docker Compose.
# When running via `docker compose up`, docker-compose.yml overrides this
# to point at the `postgres` service instead.
POSTGRES_USER=prometheus
POSTGRES_PASSWORD=prometheus
POSTGRES_DB=prometheus
DATABASE_URL=postgresql+psycopg2://prometheus:prometheus@localhost:5432/prometheus

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# --- CORS ---
# Comma-separated list is NOT supported here — this is parsed as a JSON-style
# list by pydantic-settings. Example for multiple origins:
# CORS_ORIGINS=["http://localhost:3000","https://app.example.com"]
CORS_ORIGINS=["http://localhost:3000"]

# --- Risk Engine defaults (seed values for new users' risk settings) ---
DEFAULT_RISK_PER_TRADE_PCT=1.0
DEFAULT_MAX_DAILY_LOSS_PCT=3.0
DEFAULT_MAX_DRAWDOWN_PCT=10.0
DEFAULT_MAX_OPEN_POSITIONS=10
DEFAULT_MAX_POSITIONS_PER_SYMBOL=2
DEFAULT_MAX_PORTFOLIO_EXPOSURE_PCT=50.0
DEFAULT_MAX_SYMBOL_EXPOSURE_PCT=20.0
DEFAULT_MAX_LEVERAGE=10.0
DEFAULT_STARTING_BALANCE=10000.0

# --- Market data ---
# If true, attempts a real yfinance fetch first and transparently falls back
# to labeled synthetic data on any failure (no network, bad symbol, etc).
# Set to false to always use synthetic data (useful for fully offline dev/CI).
MARKET_DATA_ALLOW_LIVE_FETCH=true

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=true
